# Mrs Content Studio — backend config
# Copy to .env.local for local dev. Without these two values the app runs in
# demo mode (in-memory, per-browser). With them, it becomes the shared team
# workspace (accounts + synced library). See docs/SUPABASE_SETUP.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
